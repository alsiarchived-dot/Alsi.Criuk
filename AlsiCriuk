    <!-- INTERACTIVE SCRIPTS -->
    <script>
        // Initialize Lucide Icons
        lucide.createIcons();

        // Mobile Menu Toggle
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');

        mobileMenuBtn.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
        });

        // Hide mobile menu on link click
        document.querySelectorAll('#mobile-menu a').forEach(link => {
            link.addEventListener('click', () => {
                mobileMenu.classList.add('hidden');
            });
        });

        // Interactive WhatsApp Order Generator Logic
        const b2cName = document.getElementById('b2c-name');
        const b2cLoc = document.getElementById('b2c-loc');
        const b2cPackage = document.getElementById('b2c-package');
        const b2cLevel = document.getElementById('b2c-level');
        const extraSauce = document.getElementById('extra-sauce');
        const doubleCrispy = document.getElementById('double-crispy');
        const liveChatPreview = document.getElementById('live-chat-preview');
        const b2cForm = document.getElementById('whatsapp-order-form');

        function updateLivePreview() {
            const name = b2cName.value.trim() || '[Nama Anda]';
            const location = b2cLoc.value.trim() || '[Lokasi / Titik Temu]';
            const packageVal = b2cPackage.value;
            const levelVal = b2cLevel.value;
            
            let extras = [];
            let priceAdjust = 0;
            if (packageVal.includes("12.000")) priceAdjust += 12000;
            if (packageVal.includes("10.000")) priceAdjust += 10000;
            if (packageVal.includes("15.000")) priceAdjust += 15000;

            if (extraSauce.checked) {
                extras.push("Ekstra Saus Keju (+Rp 3.000)");
                priceAdjust += 3000;
            }
            if (doubleCrispy.checked) {
                extras.push("Porsi Ganda / Double (+Rp 6.000)");
                priceAdjust += 6000;
            }

            const extrasText = extras.length > 0 ? extras.join(", ") : "Tidak Ada";

            const previewText = `Halo Admin Alsi Criuk! 👋
Saya ingin melakukan Pre-Order camilan crispy fresh:

👤 Nama: ${name}
📍 Lokasi COD: ${location}
📦 Menu Utama: ${packageVal}
🔥 Level Pedas: ${levelVal}
✨ Topping Tambahan: ${extrasText}

💵 Total Estimasi: Rp ${priceAdjust.toLocaleString('id-ID')}
Mohon diproses untuk pengiriman hangat kampus hari ini ya. Terima kasih!`;

            liveChatPreview.textContent = previewText;
            return { previewText, priceAdjust };
        }

        // Attach Event Listeners to B2C Form Fields
        b2cName.addEventListener('input', updateLivePreview);
        b2cLoc.addEventListener('input', updateLivePreview);
        b2cPackage.addEventListener('change', updateLivePreview);
        b2cLevel.addEventListener('change', updateLivePreview);
        extraSauce.addEventListener('change', updateLivePreview);
        doubleCrispy.addEventListener('change', updateLivePreview);

        // Submit B2C WhatsApp Order Form
        b2cForm.addEventListener('submit', (e) => {
            e.preventDefault();
            const { previewText } = updateLivePreview();
            
            // Format to WhatsApp URL Scheme
            const encodedText = encodeURIComponent(previewText);
            // Dynamic Dummy Admin Number (or actual client number in real usage)
            const waNumber = "6281233020072"; 
            const waUrl = `https://wa.me/${waNumber}?text=${encodedText}`;
            
            // Open in WhatsApp tab
            window.open(waUrl, '_blank');
        });

        // Submit B2B Partnership Form with dynamic overlay
        const b2bForm = document.getElementById('b2b-partnership-form');
        const b2bSuccessOverlay = document.getElementById('b2b-success-overlay');

        b2bForm.addEventListener('submit', (e) => {
            e.preventDefault();
            
            // Show successful submitted message state
            b2bSuccessOverlay.classList.remove('hidden');
            b2bSuccessOverlay.classList.add('flex');
        });

        function resetB2BForm() {
            b2bForm.reset();
            b2bSuccessOverlay.classList.remove('flex');
            b2bSuccessOverlay.classList.add('hidden');
        }

        // Initialize Live Preview
        updateLivePreview();
    </script>
